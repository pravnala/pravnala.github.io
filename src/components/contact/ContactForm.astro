---
interface Props {
  captchaQuestion: string;
  captchaAnswer: string;
}

const { captchaQuestion, captchaAnswer }: Props = Astro.props;
---

<form
  id="contact-form"
  method="POST"
  action=""
  novalidate
  class="reveal max-w-2xl mx-auto space-y-10"
  aria-label="Contact form"
>
  <!-- Name -->
  <div class="group">
    <label
      for="name"
      class="block text-lg text-heading mb-2 text-ink-300 group-focus-within:text-ink-100 transition-colors duration-500 ease-in-out"
    >
      Name
    </label>
    <input
      id="name"
      name="name"
      type="text"
      required
      autocomplete="name"
      class="w-full border-b border-ink-700 bg-transparent py-3 text-base text-ink-50 placeholder:opacity-30 duration-500 ease-in-out focus:outline-none focus:border-ink-100 transition-colors"
      placeholder="Your full name"
      aria-describedby="name-error"
      aria-required="true"
    />
    <p
      id="name-error"
      role="alert"
      aria-live="polite"
      class="mt-2 text-xs tracking-wide text-ink-50 opacity-0"
    >
      Name is required.
    </p>
  </div>

  <!-- Location -->
  <input
    id="location"
    name="location"
    type="text"
    data-loc={captchaAnswer}
    class="hidden"
  />

  <!-- Email -->
  <div class="group">
    <label
      for="email"
      class="block text-lg text-heading mb-2 text-ink-300 group-focus-within:text-ink-100 transition-colors duration-500 ease-in-out"
    >
      Email
    </label>
    <input
      id="email"
      name="email"
      type="email"
      required
      autocomplete="email"
      class="w-full border-b border-ink-700 bg-transparent py-3 text-base text-ink-50 placeholder:opacity-30 duration-500 ease-in-out focus:outline-none focus:border-ink-100 transition-colors"
      placeholder="you@example.com"
      aria-describedby="email-error"
      aria-required="true"
    />
    <p
      id="email-error"
      role="alert"
      aria-live="polite"
      class="mt-2 text-xs tracking-wide text-ink-50 opacity-0"
    >
      A valid email address is required.
    </p>
  </div>

  <!-- Inquiry Type -->
  <div class="group">
    <label
      for="inquiryType"
      class="block text-lg text-heading mb-2 text-ink-300 group-focus-within:text-ink-100 transition-colors duration-500 ease-in-out"
    >
      Inquiry Type
    </label>
    <div class="relative">
      <select
        id="inquiryType"
        name="inquiryType"
        required
        class="w-full border-b border-ink-700 bg-transparent py-3 text-base text-ink-50 appearance-none focus:outline-none focus:border-ink-100 transition-colors cursor-pointer"
        aria-describedby="inquiryType-error"
        aria-required="true"
      >
        <option value="" disabled selected class="text-ink-50"
          >Select an inquiry type</option
        >
        <option value="web-development" class="bg-ink-900 text-ink-50"
          >Web Development</option
        >
        <option value="arnis-fma" class="bg-ink-900 text-ink-50"
          >Arnis / Filipino Martial Arts</option
        >
        <option value="hello" class="bg-ink-900 text-ink-50"
          >Just saying hello</option
        >
      </select>
      <!-- Custom chevron -->
      <span
        class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 text-ink-50"
        aria-hidden="true"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 16 16"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M4 6L8 10L12 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </div>
    <p
      id="inquiryType-error"
      role="alert"
      aria-live="polite"
      class="mt-2 text-xs tracking-wide text-ink-50 opacity-0"
    >
      Please select an inquiry type.
    </p>
  </div>

  <!-- Message -->
  <div class="group">
    <label
      for="message"
      class="block text-lg text-heading mb-2 text-ink-300 group-focus-within:text-ink-100 transition-colors duration-500 ease-in-out"
    >
      Message
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full border-b border-ink-700 bg-transparent py-3 text-base text-ink-50 placeholder:opacity-30 duration-500 ease-in-out focus:outline-none focus:border-ink-100 transition-colors resize-none"
      placeholder="Tell me about your project or inquiry…"
      aria-describedby="message-error"
      aria-required="true"></textarea>
    <p
      id="message-error"
      role="alert"
      aria-live="polite"
      class="mt-2 text-xs tracking-wide text-ink-50 opacity-0"
    >
      Message is required.
    </p>
  </div>

  <!-- Math Captcha -->
  <div class="group">
    <label
      for="matcha"
      class="block text-lg text-heading mb-2 text-ink-300 group-focus-within:text-ink-100 transition-colors duration-500 ease-in-out"
    >
      {captchaQuestion}
    </label>
    <input
      id="matcha"
      name="matcha"
      type="text"
      required
      autocomplete="off"
      class="w-full border-b border-ink-700 bg-transparent py-3 text-base text-ink-50 placeholder:opacity-30 duration-500 ease-in-out focus:outline-none focus:border-ink-100 transition-colors"
      aria-describedby="matcha-error"
      aria-required="true"
    />
    <p
      id="matcha-error"
      role="alert"
      aria-live="polite"
      class="mt-2 text-xs tracking-wide text-ink-50 opacity-0"
    >
      Please provide the correct answer.
    </p>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    class="inline-block bg-ink-50 text-ink-900 text-sm tracking-[0.15em] uppercase px-10 py-4 transition-opacity duration-200 hover:opacity-70 focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-ink-50"
  >
    Send Message
  </button>
</form>

<!-- Success message (hidden until valid submit) -->
<div
  id="form-success"
  role="status"
  aria-live="polite"
  class="hidden text-center text-sm font-black tracking-widest uppercase text-ink-100 mx-auto"
>
  Message sent. Please give me some time to respond. Thanks!
</div>

<!-- Sending error message -->
<div
  id="sending-error"
  role="status"
  aria-live="polite"
  class="hidden text-center text-sm font-black tracking-widest uppercase text-ink-100 mx-auto"
>
  Oops! Something went wrong. Please reload the page to try again.
</div>

<script>
  const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xlgkplkr';

  interface SubmitData {
    name: string;
    email: string;
    inquiryType: string;
    message: string;
  }

  async function handleSubmit(data: SubmitData): Promise<boolean> {
    const inquiryLabels: Record<string, string> = {
      'web-development': 'Web Development',
      'arnis-fma': 'Arnis / Filipino Martial Arts',
      hello: 'Just saying hello',
    };

    const res = await fetch(FORMSPREE_ENDPOINT, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: data.name,
        email: data.email,
        _replyto: data.email,
        _subject: `[${inquiryLabels[data.inquiryType] ?? data.inquiryType}] New message from ${data.name}`,
        'Inquiry Type': inquiryLabels[data.inquiryType] ?? data.inquiryType,
        message: data.message,
      }),
    });

    return res.ok;
  }

  document.addEventListener('astro:page-load', () => {
    // Pre-select inquiry type from URL query param (?type=web-development etc.)
    const params = new URLSearchParams(window.location.search);
    const typeParam = params.get('type');
    if (typeParam) {
      const select = document.getElementById(
        'inquiryType'
      ) as HTMLSelectElement | null;
      if (select) {
        const match = Array.from(select.options).find(
          (o) => o.value === typeParam
        );
        if (match) select.value = typeParam;
      }
    }

    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const form = document.getElementById(
      'contact-form'
    ) as HTMLFormElement | null;
    const submitBtn = form?.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement | null;

    if (form && submitBtn) {
      form.addEventListener('submit', async (e: Event) => {
        e.preventDefault();

        const nameEl = document.getElementById('name') as HTMLInputElement;
        const emailEl = document.getElementById('email') as HTMLInputElement;
        const inquiryEl = document.getElementById(
          'inquiryType'
        ) as HTMLSelectElement;
        const messageEl = document.getElementById(
          'message'
        ) as HTMLTextAreaElement;
        const matchaInput = document.getElementById(
          'matcha'
        ) as HTMLInputElement;
        const locationEl = document.getElementById(
          'location'
        ) as HTMLInputElement;

        const nameErr = document.getElementById('name-error')!;
        const emailErr = document.getElementById('email-error')!;
        const inquiryErr = document.getElementById('inquiryType-error')!;
        const messageErr = document.getElementById('message-error')!;
        const successMsg = document.getElementById('form-success')!;
        const matchaErr = document.getElementById('matcha-error')!;
        const sendingError = document.getElementById('sending-error')!;

        // Reset errors
        [nameErr, emailErr, inquiryErr, messageErr, matchaErr].forEach((el) =>
          el.classList.replace('opacity-60', 'opacity-0')
        );
        successMsg.classList.add('hidden');
        sendingError.classList.add('hidden');

        let valid = true;

        if (!nameEl.value.trim()) {
          nameErr.classList.replace('opacity-0', 'opacity-60');
          valid = false;
        }

        if (!emailEl.value.trim() || !EMAIL_RE.test(emailEl.value.trim())) {
          emailErr.classList.replace('opacity-0', 'opacity-60');
          valid = false;
        }

        if (!inquiryEl.value) {
          inquiryErr.classList.replace('opacity-0', 'opacity-60');
          valid = false;
        }

        if (!messageEl.value.trim()) {
          messageErr.classList.replace('opacity-0', 'opacity-60');
          valid = false;
        }

        // Honeypot: hidden field must remain empty
        if (locationEl.value.trim() !== '') {
          valid = false;
        }

        // Math captcha
        if (locationEl.dataset.loc?.trim() !== matchaInput.value.trim()) {
          matchaErr.classList.replace('opacity-0', 'opacity-60');
          valid = false;
        }

        if (!valid) return;

        // Show loading state
        const originalLabel = submitBtn.textContent ?? 'Send Message';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending…';
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');

        const ok = await handleSubmit({
          name: nameEl.value.trim(),
          email: emailEl.value.trim(),
          inquiryType: inquiryEl.value,
          message: messageEl.value.trim(),
        });

        // Restore button regardless of outcome
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');

        form.reset();
        form.classList.add('hidden');

        if (ok) {
          successMsg.classList.remove('hidden');
        } else {
          sendingError.classList.remove('hidden');
        }
      });
    }
  });
</script>

<style>
  /* Disable Chrome's autofill background and text styling */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    transition:
      background-color 5000s ease-in-out 0s,
      color 5000s ease-in-out 0s;
  }
</style>
