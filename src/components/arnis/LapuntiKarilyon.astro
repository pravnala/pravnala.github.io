---
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';
import data from '../../data/arnis/karilyon.json';

const {
  eyebrow,
  heading,
  description,
  details,
  trainingCardHeading,
  trainingLabels,
  training,
  link,
} = data;
const headingLines = heading.split('\n');
---

<section
  class="reveal section-container bg-ink-700"
  aria-labelledby="karilyon-heading"
>
  <h2 id="karilyon-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <p class="reveal text-heading mb-6">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <p
    class="reveal text-sm md:text-base leading-relaxed text-ink-200 max-w-3xl mb-12"
  >
    {description}
  </p>

  <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Details -->
    <div class="space-y-4">
      {
        details.map((detail) => (
          <p class="text-sm leading-relaxed text-ink-300">{detail}</p>
        ))
      }
    </div>

    <!-- Training Info -->
    <div
      class="border border-ink-600 p-8 hover:border-ink-500 duration-500 hover:-translate-y-3 transition-all ease-in-out"
    >
      <h3 class="text-xl md:text-2xl font-black tracking-[-0.02em] mb-6">
        {trainingCardHeading}
      </h3>
      <dl class="space-y-4">
        <div>
          <dt
            class="text-xs font-bold tracking-[0.15em] uppercase text-ink-500 mb-1"
          >
            {trainingLabels.schedule}
          </dt>
          <dd class="text-sm text-ink-100">{training.schedule}</dd>
        </div>
        <div>
          <dt
            class="text-xs font-bold tracking-[0.15em] uppercase text-ink-500 mb-1"
          >
            {trainingLabels.venue}
          </dt>
          <dd class="text-sm text-ink-100">{training.venue}</dd>
        </div>
        <div>
          <dt
            class="text-xs font-bold tracking-[0.15em] uppercase text-ink-500 mb-1"
          >
            {trainingLabels.location}
          </dt>
          <dd class="text-sm text-ink-100">{training.location}</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Link to Lapunti site -->
  <div class="reveal mt-12">
    <Button
      variant="secondary"
      href={link.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex gap-2"
    >
      {link.label}
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
        ></path>
        <polyline points="15 3 21 3 21 9"></polyline>
        <line x1="10" y1="14" x2="21" y2="3"></line>
      </svg>
    </Button>
  </div>
</section>
