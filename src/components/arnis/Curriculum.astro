---
import data from '../../data/arnis/curriculum.json';

const { eyebrow, heading, disciplinesHeading, tracks, weapons } = data;
const headingLines = heading.split('\n');
---

<section
  class="section-container bg-ink-900"
  aria-labelledby="curriculum-heading"
>
  <h2 id="curriculum-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <p class="reveal text-heading mb-12">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <!-- Training Tracks -->
  <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
    {
      tracks.map(({ title, description, badge }) => (
        <div class="group relative border border-ink-600 p-8 hover:border-ink-500 hover:-translate-y-3 transition-all duration-500 cursor-default hover:bg-ink-900">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-xl md:text-2xl font-black tracking-[-0.02em] text-ink-300 group-hover:text-ink-50 transition-colors duration-500 ease-in-out">
              {title}
            </h3>
            <span class="absolute right-8 text-[10px] font-bold tracking-[0.15em] uppercase px-2 py-1 border border-ink-500/50 text-ink-400 group-hover:text-ink-200 group-hover:border-ink-500 transition-colors duration-500 ease-in-out">
              {badge}
            </span>
          </div>
          <p
            class="text-sm leading-relaxed text-ink-300"
            set:html={description}
          />
        </div>
      ))
    }
  </div>

  <!-- Weapon Categories -->
  <div class="reveal border-t border-ink-700 pt-12">
    <h3 class="reveal text-xl md:text-2xl font-black tracking-[-0.02em] mb-8">
      {disciplinesHeading}
    </h3>
    <div class="reveal grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      {
        weapons.map(({ name, description }) => (
          <div class="group cursor-default">
            <p class="text-sm font-bold text-ink-100 mb-1 group-hover:text-ink-50 transition-colors duration-500">
              {name}
            </p>
            <p class="text-xs text-ink-400 group-hover:text-ink-300 transition-colors duration-500">
              {description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
