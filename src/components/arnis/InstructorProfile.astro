---
import data from '../../data/arnis/instructorProfile.json';

const {
  eyebrow,
  heading,
  lineageHeading,
  timelineHeading,
  narrative,
  credentials,
  lineage,
  timeline,
} = data;
const headingLines = heading.split('\n');
---

<section
  class="reveal section-container bg-ink-300 text-ink-900"
  aria-labelledby="instructor-profile-heading"
>
  <h2 id="instructor-profile-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <p class="reveal text-heading mb-12">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-16">
    <!-- Narrative -->
    <div class="space-y-4">
      {
        narrative.map((paragraph) => (
          <p
            class="reveal text-sm md:text-base leading-relaxed text-ink-800"
            set:html={paragraph}
          />
        ))
      }

      <!-- Credentials -->
      <div class="reveal pt-8 space-y-3">
        <p class="text-sm text-ink-700" set:html={credentials.rank} />
        <p class="text-sm text-ink-700">
          {credentials.promotedBy}
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          {
            credentials.organizations.map(({ name, url }) =>
              url ? (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs inline-flex gap-2 font-bold tracking-wide uppercase px-3 py-1.5 border border-ink-500 text-ink-600 hover:border-ink-900 hover:text-ink-900 transition-colors duration-500 ease-in-out"
                >
                  {name}
                  <svg
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" y1="14" x2="21" y2="3" />
                  </svg>
                </a>
              ) : (
                <span class="text-xs font-bold tracking-wide uppercase px-3 py-1.5 border  border-ink-500 text-ink-600 hover:border-ink-900 hover:text-ink-900 transition-colors duration-500 ease-in-out cursor-default">
                  {name}
                </span>
              )
            )
          }
        </div>
      </div>
    </div>

    <!-- Timeline & Lineage -->
    <div>
      <!-- Lineage -->
      <div class="mb-12">
        <h3
          class="reveal text-xl md:text-2xl font-black tracking-[-0.02em] mb-6"
        >
          {lineageHeading}
        </h3>
        <ol class="reveal relative ml-2">
          <span
            class="absolute left-0 top-2 bottom-2 w-px bg-ink-500"
            aria-hidden="true"></span>
          {
            lineage.map(({ names, title }, i) => (
              <li class={`relative pl-8 ${i > 0 ? 'mt-4' : ''}`}>
                <span
                  class="absolute left-0 top-2 w-3 h-3 -translate-x-1/2 rounded-full bg-ink-400"
                  aria-hidden="true"
                />
                <p class="text-sm font-bold text-ink-600 mb-1">
                  {names.join(' & ')}
                </p>
                <p class="text-xs text-ink-600">{title}</p>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Timeline -->
      <div>
        <h3
          class="reveal text-xl md:text-2xl font-black tracking-[-0.02em] mb-6"
        >
          {timelineHeading}
        </h3>
        <ol class="reveal relative ml-2">
          <span
            class="absolute left-0 top-2 bottom-2 w-px bg-ink-500"
            aria-hidden="true"></span>
          {
            timeline.map(({ year, event }, i) => (
              <li class={`relative pl-8 ${i > 0 ? 'mt-5' : ''}`}>
                <span
                  class="absolute left-0 top-2 w-3 h-3 -translate-x-1/2 rounded-full bg-ink-400"
                  aria-hidden="true"
                />
                <p class="text-xs font-bold tracking-widest uppercase text-ink-600 mb-1">
                  {year}
                </p>
                <p class="text-sm text-ink-600">{event}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
