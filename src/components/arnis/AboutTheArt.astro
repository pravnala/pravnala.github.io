---
import data from '../../data/arnis/aboutTheArt.json';

const { eyebrow, heading, intro, characteristics, founders, acronym } = data;
const headingLines = heading.split('\n');
---

<section
  class="reveal section-container bg-ink-900"
  aria-labelledby="about-the-art-heading"
>
  <h2 id="about-the-art-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <p class="reveal text-heading mb-6">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <p
    class="reveal text-sm md:text-base leading-relaxed text-ink-300 max-w-3xl mb-12"
    set:html={intro}
  />

  <!-- Characteristics -->
  <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
    {
      characteristics.map(({ title, description }) => (
        <div class="group border-3 border-ink-600 p-8 hover:border-ink-300 hover:-translate-y-3 transition-all duration-500 ease-in-out cursor-default">
          <h3 class="text-xl text-ink-200 md:text-3xl font-black tracking-[-0.02em] mb-3 group-hover:text-ink-50 transition-colors duration-500 ease-in-out">
            {title}
          </h3>
          <p class="text-sm md:text-base leading-relaxed text-ink-300">
            {description}
          </p>
        </div>
      ))
    }
  </div>

  <!-- Founders -->
  <p
    class="reveal text-sm leading-relaxed text-ink-400 max-w-3xl mb-8 tracking-wide"
  >
    {founders}
  </p>

  <!-- LAPUNTI Acronym -->
  <!-- <div class="reveal border-t border-ink-700 pt-8">
    <p class="text-xs font-bold tracking-[0.15em] uppercase text-ink-500 mb-4">
      {acronym.label}
    </p>
    <div class="flex flex-wrap gap-x-6 gap-y-2">
      {
        acronym.values.map((value) => (
          <span class="text-sm text-ink-200 font-bold">{value}</span>
        ))
      }
    </div>
  </div> -->

  <div
    class="text-sm reveal text-ink-500 border-t border-ink-700 pt-8 tracking-wide"
  >
    <p class="leading-relaxed mb-3">
      <b>LAPUNTI:</b> The three <i>barangays</i> in Cebu where the Caburnays lived
      and honed the art, and the core ideals every practitioner strives to embody.
    </p>
    <div class="mb-3">Labangon • Punta Princesa • Tisa</div>
    <div class="">
      Love • Artistry • Philosphy • Unity • Nimbleness • Truthfulness •
      Integrity
    </div>
  </div>
</section>
