---
import data from '../../data/arnis/aboutTheArt.json';

const { eyebrow, heading, intro, characteristics, founders, acronym } = data;
const headingLines = heading.split('\n');
---

<section
  class="reveal section-container bg-ink-900"
  aria-labelledby="about-the-art-heading"
>
  <h2 id="about-the-art-heading" class="text-eyebrow">{eyebrow}</h2>

  <p class="text-heading mb-6">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <p class="text-sm md:text-base leading-relaxed text-ink-300 max-w-3xl mb-12">
    {intro}
  </p>

  <!-- Characteristics -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
    {
      characteristics.map(({ title, description }) => (
        <div class="border-3 border-ink-600 p-8 hover:border-ink-500 hover:-translate-y-1 transition-all duration-500 cursor-default">
          <h3 class="text-xl md:text-2xl font-black tracking-[-0.02em] mb-3">
            {title}
          </h3>
          <p class="text-sm leading-relaxed text-ink-300">{description}</p>
        </div>
      ))
    }
  </div>

  <!-- Founders -->
  <p class="text-sm leading-relaxed text-ink-400 max-w-3xl mb-12">
    {founders}
  </p>

  <!-- LAPUNTI Acronym -->
  <div class="border-t border-ink-700 pt-8">
    <p class="text-xs font-bold tracking-[0.15em] uppercase text-ink-500 mb-4">
      {acronym.label}
    </p>
    <div class="flex flex-wrap gap-x-6 gap-y-2">
      {
        acronym.values.map((value) => (
          <span class="text-sm text-ink-200 font-bold">{value}</span>
        ))
      }
    </div>
  </div>
</section>
