---
import data from '../../data/arnis/aboutTheArt.json';
import { Image } from 'astro:assets';

const { eyebrow, heading, intro, characteristics, founders, acronym } = data;
const headingLines = heading.split('\n');

import ladaiLogo from '../../assets/images/arnis/LADAI-logo-colored.webp';
---

<section
  class="section-container relative bg-ink-900"
  aria-labelledby="about-the-art-heading"
>
  <h2 id="about-the-art-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <Image
    src={ladaiLogo}
    alt="LADAI Logo"
    width={180}
    height={180}
    class="reveal md:hidden mb-6"
  />

  <div class="flex items-start space-x-4 mb-12">
    <div>
      <p class="reveal text-heading mb-6">
        {
          headingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </p>

      <p
        class="reveal text-sm md:text-base leading-relaxed text-ink-300 max-w-lg"
        set:html={intro}
      />
    </div>

    <Image
      src={ladaiLogo}
      alt="LADAI Logo"
      width={260}
      height={260}
      class="reveal hidden md:inline w-[220px] lg:w-[260px]"
    />
  </div>

  <!-- Characteristics -->
  <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
    {
      characteristics.map(({ title, description }) => (
        <div class="group border-3 border-ink-600 p-8 hover:border-ink-300 hover:-translate-y-3 transition-all duration-500 ease-in-out cursor-default">
          <h3 class="text-xl text-ink-200 md:text-3xl font-black tracking-[-0.02em] mb-3 group-hover:text-ink-50 transition-colors duration-500 ease-in-out">
            {title}
          </h3>
          <p class="text-sm md:text-base leading-relaxed text-ink-300">
            {description}
          </p>
        </div>
      ))
    }
  </div>

  <!-- Founders -->
  <p
    class="reveal text-sm leading-relaxed text-ink-400 max-w-3xl mb-8 tracking-wide"
  >
    {founders}
  </p>

  <!-- LAPUNTI Acronym -->
  <div class="reveal border-t border-ink-700 pt-8">
    <p class="text-xs font-bold tracking-[0.15em] uppercase text-ink-300 mb-4">
      {acronym.label}
    </p>
    <div class="mb-3 tracking-wider text-sm uppercase">
      La<span class="text-ink-400">bangon</span> • Pun<span class="text-ink-400"
        >ta Princesa</span
      > • Ti<span class="text-ink-400">sa</span>
    </div>
    <div class="flex flex-wrap gap-x-3 gap-y-2 text-sm">
      {
        acronym.values.map((value) => (
          <span class="text-ink-200 font-bold tracking-wider flex">
            <span class="text-ink-100">{value.charAt(0)}</span>
            <span class="text-ink-500">{value.substring(1)}</span>
          </span>
        ))
      }
    </div>
  </div>
</section>
