---
import goodFitData from '../../data/dev/goodFit.json';

const {
  heading,
  pageHeading,
  description,
  fitHeading,
  notFitHeading,
  items,
  notFit,
} = goodFitData;
const pageHeadingLines = pageHeading.split('\n');
---

<section
  class="reveal section-container bg-ink-900"
  aria-labelledby="good-fit-heading"
>
  <h2 id="good-fit-heading" class="reveal text-eyebrow">{heading}</h2>

  <p class="reveal text-heading mb-6">
    {
      pageHeadingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>
  <p class="reveal leading-relaxed text-ink-300 mb-12 max-w-prose">
    {description}
  </p>

  <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Fit card -->
    <div
      class="border border-ink-600 p-8 md:p-10 border-l-4 border-l-ink-400 hover:border-ink-500 hover:-translate-y-3 transition-all duration-500 ease-in-out"
    >
      <h3
        class="text-xl md:text-3xl font-black tracking-[-0.02em] mb-6 text-ink-50"
      >
        {fitHeading}
      </h3>
      <ul class="space-y-5" role="list">
        {
          items.map((item) => (
            <li class="flex items-start gap-3 text-sm md:text-base leading-relaxed text-ink-200">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-ink-300 shrink-0 mt-0.5"
                aria-hidden="true"
              >
                <polyline points="20 6 9 17 4 12" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Not a fit card -->
    <div
      class="border border-ink-700 p-8 md:p-10 hover:border-ink-600 hover:-translate-y-3 transition-all duration-500 ease-in-out"
    >
      <h3
        class="text-xl md:text-2xl font-black tracking-[-0.02em] mb-6 text-ink-400"
      >
        {notFitHeading}
      </h3>
      <ul class="space-y-5" role="list">
        {
          notFit.map((item) => (
            <li class="flex items-start gap-3 text-sm md:text-base leading-relaxed text-ink-400">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-ink-600 shrink-0 mt-0.5"
                aria-hidden="true"
              >
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
