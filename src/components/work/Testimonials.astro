---
import testimonials from '../../data/dev/testimonials.json';
---

{
  testimonials.length > 0 && (
    <section
      class="reveal section-container bg-ink-700"
      aria-labelledby="testimonials-heading"
    >
      <h2 id="testimonials-heading" class="text-eyebrow">
        Testimonials
      </h2>

      <p class="text-heading mb-12">
        What Others
        <br />
        Say
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {testimonials.map(({ quote, name, role, company, image }) => (
          <blockquote class="relative border border-ink-600 p-8 md:p-10 flex flex-col gap-6 hover:border-ink-500 hover:bg-ink-600/50 hover:-translate-y-1 transition-all duration-500">
            {/* Quote mark */}
            <span
              class="absolute top-4 right-6 text-6xl font-black text-ink-600/50 leading-none select-none pointer-events-none"
              aria-hidden="true"
            >
              &ldquo;
            </span>

            {/* Quote text */}
            <p class="text-sm md:text-base leading-relaxed text-ink-200 italic relative z-10">
              {quote}
            </p>

            {/* Attribution */}
            <footer class="flex items-center gap-4 mt-auto pt-2">
              {/* Avatar */}
              <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-ink-500 shrink-0 bg-ink-800 flex items-center justify-center">
                {image ? (
                  <img
                    src={image}
                    alt={`${name} photo`}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-ink-400"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="8" r="4" />
                    <path d="M20 21a8 8 0 1 0-16 0" />
                  </svg>
                )}
              </div>

              {/* Name & role */}
              <div>
                <cite class="not-italic text-sm font-bold text-ink-50 block">
                  {name}
                </cite>
                <span class="text-xs text-ink-400">
                  {role}
                  {company && `, ${company}`}
                </span>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </section>
  )
}
