---
import data from '../../data/dev/testimonials.json';

const { eyebrow, heading, items: testimonials } = data;
const headingLines = heading.split('\n');
---

{
  testimonials.length > 0 && (
    <section
      class="section-container bg-ink-50 text-ink-900"
      aria-labelledby="testimonials-heading"
    >
      <h2 id="testimonials-heading" class="text-eyebrow">
        {eyebrow}
      </h2>

      <p class="text-heading mb-12">
        {headingLines.map((line, i) => (
          <>
            {i > 0 && <br />}
            {line}
          </>
        ))}
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {testimonials.map(({ quote, name, role, company, image }) => (
          <blockquote class="relative border border-ink-400/40 p-8 md:p-10 flex flex-col gap-6 hover:border-ink-600 hover:bg-ink-600/10 hover:-translate-y-1 transition-all duration-500">
            <span
              class="absolute top-4 right-6 text-6xl font-black text-ink-400/30 leading-none select-none pointer-events-none"
              aria-hidden="true"
            >
              &ldquo;
            </span>
            <p class="text-sm md:text-base leading-relaxed text-ink-700 italic relative z-10">
              {quote}
            </p>
            <footer class="flex items-center gap-4 mt-auto pt-2">
              <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-ink-400 shrink-0 bg-ink-200 flex items-center justify-center">
                {image ? (
                  <img
                    src={image}
                    alt={`${name} photo`}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-ink-500"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="8" r="4" />
                    <path d="M20 21a8 8 0 1 0-16 0" />
                  </svg>
                )}
              </div>
              <div>
                <cite class="not-italic text-sm font-bold text-ink-900 block">
                  {name}
                </cite>
                <span class="text-xs text-ink-500">
                  {role}
                  {company && `, ${company}`}
                </span>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </section>
  )
}
