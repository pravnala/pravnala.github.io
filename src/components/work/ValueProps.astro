---
import data from '../../data/dev/valueProps.json';

const { eyebrow, heading, items } = data;
const headingLines = heading.split('\n');
---

<section
  class="section-container bg-ink-100 text-ink-900"
  aria-labelledby="value-props-heading"
>
  <h2 id="value-props-heading" class="reveal text-eyebrow">{eyebrow}</h2>

  <p class="reveal text-heading mb-12">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <div class="reveal grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8">
    {
      items.map(({ title, description }) => (
        <div
          class:list={[
            'group border-3 border-ink-300 p-8 transition-all ease-in-out duration-500 cursor-default bg-ink-800/20 text-ink-800',
            'hover:border-ink-800 hover:bg-ink-800 hover:-translate-y-3 hover:text-ink-50',
          ]}
        >
          <h3 class="text-xl md:text-3xl font-black tracking-[-0.02em] mb-3">
            {title}
          </h3>
          <p class="text-sm leading-relaxed text-ink-700 group-hover:text-ink-200">
            {description}
          </p>
        </div>
      ))
    }
  </div>
</section>
