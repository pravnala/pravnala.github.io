---
import data from '../../data/dev/valueProps.json';

const { eyebrow, heading, items } = data;
const headingLines = heading.split('\n');
---

<section
  class="reveal section-container bg-ink-700"
  aria-labelledby="value-props-heading"
>
  <h2 id="value-props-heading" class="text-eyebrow">{eyebrow}</h2>

  <p class="text-heading mb-12">
    {
      headingLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))
    }
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      items.map(({ title, description }) => (
        <div class="border border-ink-600 p-8 hover:border-ink-500 hover:bg-ink-600/50 hover:-translate-y-1 transition-all duration-500 cursor-default">
          <h3 class="text-xl md:text-2xl font-black tracking-[-0.02em] mb-3 text-ink-50">
            {title}
          </h3>
          <p class="text-sm leading-relaxed text-ink-300">{description}</p>
        </div>
      ))
    }
  </div>
</section>
