---
import { getCollection } from 'astro:content';
import CaseStudyCard from '../../components/work/CaseStudyCard.astro';
import meta from '../../data/dev/caseStudies.json';

const { eyebrow, heading, emptyMessage } = meta;
const headingLines = heading.split('\n');

const allWork = await getCollection('work');
const publicWork = allWork
  .filter((entry) => entry.data.isPublic)
  .sort((a, b) => {
    const aOrder = a.data.order ?? Infinity;
    const bOrder = b.data.order ?? Infinity;
    return aOrder - bOrder;
  });
---

<section
  class="section-container bg-ink-900"
  aria-labelledby="case-studies-heading"
>
  {
    publicWork.length === 0 ? (
      <p class="reveal text-eyebrow">{emptyMessage}</p>
    ) : (
      <>
        <h2 id="case-studies-heading" class="reveal text-eyebrow">
          {eyebrow}
        </h2>
        <p class="reveal text-heading mb-7">
          {headingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))}
        </p>
        <p class="reveal mb-12 text-ink-300">
          A showcase of some recent projects not covered by NDA.
        </p>
        <div class="reveal flex flex-wrap gap-8 justify-center md:justify-start">
          {publicWork.map((entry) => (
            <CaseStudyCard
              title={entry.data.title}
              slug={entry.id}
              projectContext={entry.data.projectContext}
              technologies={entry.data.technologies}
              coverImage={entry.data.coverImage}
              externalUrl={entry.data.externalUrl}
              externalLabel={entry.data.externalLabel}
              hasDetailPage={entry.data.hasDetailPage}
            />
          ))}
        </div>
      </>
    )
  }
</section>
