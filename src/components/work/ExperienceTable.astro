---
// No props — static hardcoded data (NDA/private projects, no confidential details)

const experiences = [
  {
    industry: 'FinTech',
    role: 'Senior Full-Stack Developer',
    technologies: ['React', 'Node.js', 'PostgreSQL', 'AWS'],
  },
  {
    industry: 'Healthcare',
    role: 'Lead Frontend Engineer',
    technologies: ['Vue.js', 'TypeScript', 'REST APIs'],
  },
  {
    industry: 'E-Commerce',
    role: 'Full-Stack Developer',
    technologies: ['Next.js', 'Shopify', 'GraphQL'],
  },
  {
    industry: 'SaaS Platform',
    role: 'Frontend Architect',
    technologies: ['React', 'Redux', 'Tailwind CSS'],
  },
  {
    industry: 'Government',
    role: 'Web Developer',
    technologies: ['PHP', 'Laravel', 'MySQL'],
  },
] as const;
---

<section aria-labelledby="experience-heading">
  <h2
    id="experience-heading"
    class="text-4xl md:text-5xl font-black tracking-[-0.04em] leading-[1.05] mb-10"
  >
    Selected Experience
  </h2>

  <div class="overflow-x-auto">
    <table
      class="w-full border-collapse text-sm"
      aria-label="Selected NDA and private project experience"
    >
      <thead>
        <tr class="border-b-2 border-ink-50">
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-8"
          >
            Industry
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-8"
          >
            Role
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4"
          >
            Technologies
          </th>
        </tr>
      </thead>
      <tbody>
        {
          experiences.map((entry, i) => (
            <tr
              class={`border-b border-ink-50 ${i % 2 === 0 ? '' : 'bg-ink-800'}`}
            >
              <td class="py-5 pr-8 font-bold align-top whitespace-nowrap">
                {entry.industry}
              </td>
              <td class="py-5 pr-8 align-top whitespace-nowrap">
                {entry.role}
              </td>
              <td class="py-5 align-top">
                <ul
                  class="flex flex-wrap gap-2"
                  aria-label={`Technologies for ${entry.industry} role`}
                >
                  {entry.technologies.map((tech) => (
                    <li class="text-xs font-bold tracking-widest uppercase border border-ink-50 px-2 py-1">
                      {tech}
                    </li>
                  ))}
                </ul>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <p class="mt-6 text-xs tracking-widest uppercase opacity-50">
    * Project details withheld under NDA. Industry, role, and tech stack listed
    only.
  </p>
</section>
