---
import experiences from '../../data/dev/experience.json';
---

<section
  class="reveal section-container bg-ink-700"
  aria-labelledby="experience-heading"
>
  <h2 id="experience-heading" class="text-eyebrow">Career</h2>

  <p class="text-heading mb-12">Selected<br />Experience</p>

  <div class="overflow-x-auto">
    <table
      class="w-full border-collapse text-sm"
      aria-label="Professional experience timeline"
    >
      <thead>
        <tr class="border-b-2 border-ink-600">
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pl-4 pr-6"
          >
            Period
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-6"
          >
            Company
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-6"
          >
            Role
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-6 hidden lg:table-cell"
          >
            Scope
          </th>
          <th
            scope="col"
            class="text-left text-xs font-bold tracking-[0.15em] uppercase pb-4 pr-4"
          >
            Tech
          </th>
        </tr>
      </thead>
      <tbody>
        {
          experiences.map((entry, i) => (
            <tr
              class={`transition-colors duration-500 cursor-default ${i % 2 === 0 ? 'hover:bg-ink-600/50' : 'bg-ink-800/50 hover:bg-ink-600/70'}`}
            >
              <td class="py-5 pl-4 pr-6 align-top whitespace-nowrap text-ink-300 text-xs">
                {entry.period}
              </td>
              <td class="py-5 pr-6 font-bold align-top whitespace-nowrap">
                {entry.company}
              </td>
              <td class="py-5 pr-6 align-top text-ink-200">{entry.role}</td>
              <td class="py-5 pr-6 align-top text-ink-300 hidden lg:table-cell max-w-xs">
                {entry.scope}
              </td>
              <td class="py-5 pr-4 align-top">
                <ul
                  class="flex flex-wrap gap-1.5"
                  aria-label={`Technologies at ${entry.company}`}
                >
                  {entry.technologies.map((tech) => (
                    <li class="text-[10px] font-bold tracking-widest uppercase border border-ink-600 px-2 py-0.5 text-ink-300">
                      {tech}
                    </li>
                  ))}
                </ul>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
