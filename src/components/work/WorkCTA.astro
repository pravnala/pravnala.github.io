---
import BtnArrow from '../common/BtnArrow.astro';
import Button from '../common/Button.astro';
---

<section
  aria-labelledby="cta-heading"
  class="section-container bg-ink-100 block md:flex md:flex-row md:items-end md:justify-between"
>
  <h2 id="cta-heading" class="text-heading text-ink-900 mb-8 md:mb-0">
    Ready to work<br />together?
  </h2>
  <Button variant="primary" href="/contact" class="inline-flex gap-2">
    Get in Touch
    <BtnArrow />
  </Button>
</section>
