---
import { Image } from 'astro:assets';
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';
import placeholderImage from '../../assets/images/case-study-placeholder.png';

interface Props {
  title: string;
  slug: string;
  projectContext: string;
  technologies: string[];
  coverImage?: string;
  externalUrl?: string;
  externalLabel?: string;
  hasDetailPage?: boolean;
}

const {
  title,
  slug,
  projectContext,
  technologies,
  coverImage,
  externalUrl,
  externalLabel = 'View Project',
  hasDetailPage = true,
} = Astro.props;

// Truncate projectContext to ~200 chars for the card summary
// const summary =
//   projectContext.length > 200
//     ? projectContext.slice(0, 157).trimEnd() + '…'
//     : projectContext;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/case-studies/*.{jpeg,jpg,png,gif,webp,svg}',
  { eager: true }
);
const imagePath = `/src/assets/images/case-studies/${coverImage}`;

const projectImage =
  coverImage && images[imagePath]
    ? images[imagePath].default
    : placeholderImage;
---

<article
  class:list={[
    'group relative border-4 border-ink-700 bg-ink-700 flex flex-col',
    'transition-all duration-500 ease-in-out hover:bg-ink-600 hover:-translate-y-3 hover:border-ink-600',
    'max-w-lg overflow-hidden',
  ]}
>
  <!-- Cover image -->
  <div class="w-full h-64 md:h-82 overflow-hidden">
    <Image
      src={projectImage}
      alt={`${title} project screenshot`}
      class="w-full h-full object-cover object-top duration-500 group-hover:scale-110"
      widths={[400, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 400px"
    />
  </div>

  <div class="p-8 md:p-10 flex flex-col gap-6 grow">
    <!-- Title -->
    <h3
      class="text-3xl md:text-4xl font-black tracking-[-0.04em] leading-[1.05]"
    >
      {title}
    </h3>

    <!-- Project context summary -->
    <p class="text-sm leading-relaxed text-ink-200 max-w-prose">
      {projectContext}
    </p>

    <!-- Technologies -->
    {
      technologies.length > 0 && (
        <ul class="flex flex-wrap gap-2" aria-label="Technologies used">
          {technologies.map((tech) => (
            <li class="text-xs tracking-[0.12em] leading-5 text-ink-300 uppercase border border-ink-500/50 px-2 py-1.5 bg-ink-800/50 group-hover:border-ink-400/50 transition-colors duration-500">
              {tech}
            </li>
          ))}
        </ul>
      )
    }

    <!-- Actions -->
    <div class="flex flex-wrap gap-3 mt-auto pt-2">
      {
        hasDetailPage && (
          <Button href={`/dev/${slug}`} class="inline-flex gap-2 px-2 py-1">
            View Details <BtnArrow />
          </Button>
        )
      }
      {
        externalUrl && (
          <Button
            href={externalUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="secondary"
            class="inline-flex gap-2 px-2 py-1"
          >
            {externalLabel}
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
          </Button>
        )
      }
    </div>
  </div>
</article>
