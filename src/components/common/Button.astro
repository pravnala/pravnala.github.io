---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  [key: string]: unknown;
}

const { href, variant = 'primary', ...rest }: Props = Astro.props;

const classList = [
  'inline-block px-3 md:px-8 py-3 md:py-4 text-xs md:text-sm font-normal uppercase tracking-widest text-center',
  'transition-colors duration-600 ease-in-out',
  'border-2',
  'focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-paper',
  variant === 'primary'
    ? 'bg-canvas text-ink hover:bg-ink-muted hover:text-canvas border-canvas'
    : 'bg-ink text-canvas hover:bg-ink-subtle hover:text-ink border-canvas',
  rest?.class,
];
---

<a href={href} class:list={classList} aria-label="View My Work" {...rest}>
  <slot />
</a>
