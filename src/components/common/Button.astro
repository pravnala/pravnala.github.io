---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  [key: string]: unknown;
}

const { href, variant = 'primary', ...rest }: Props = Astro.props;

const classList = [
  'inline-block px-3 md:px-8 py-3 md:py-4 text-xs md:text-sm font-normal uppercase tracking-widest text-center',
  'transition-colors duration-600 ease-in-out',
  'border-2',
  'focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-ink-900',
  variant === 'primary'
    ? 'bg-ink-900 text-ink-50 hover:bg-ink-300 hover:text-ink-900 border-ink-900'
    : 'bg-ink-50 text-ink-900 hover:bg-ink-500 hover:text-ink-50 border-ink-900',
  rest?.class,
];
---

<a href={href} class:list={classList} aria-label="View My Work" {...rest}>
  <slot />
</a>
