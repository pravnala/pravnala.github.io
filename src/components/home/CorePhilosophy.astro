---
const values = [
  {
    title: 'Precision',
    body: 'Every line of code and every strike is deliberate. Sloppy work — in software or in practice — compounds into failure.',
  },
  {
    title: 'Discipline',
    body: 'Mastery is not a destination. It is a daily commitment to showing up, doing the work, and refining what came before.',
  },
  {
    title: 'Craftsmanship',
    body: 'The difference between good and great is invisible to most — and essential to me. Details are not optional.',
  },
  {
    title: 'Continuous Improvement',
    body: 'Twenty years of web development and sixteen years of Arnis share one truth: there is always a better way. Find it.',
  },
];
---

<section
  class="px-6 md:px-16 py-section border-t border-ink"
  aria-labelledby="philosophy-heading"
>
  <p class="text-xs font-bold tracking-[0.2em] uppercase opacity-40 mb-6">
    Philosophy
  </p>
  <h2
    id="philosophy-heading"
    class="text-5xl md:text-7xl font-black tracking-[-0.04em] leading-[1.05] mb-16 max-w-2xl"
  >
    Core<br />Values
  </h2>

  <dl class="grid grid-cols-1 md:grid-cols-2 gap-px border border-ink">
    {
      values.map((value) => (
        <div class="p-8 md:p-10 border-ink">
          <dt class="text-xl font-black tracking-[-0.03em] leading-[1.05] mb-3">
            {value.title}
          </dt>
          <dd class="text-sm leading-relaxed opacity-60 max-w-sm">
            {value.body}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
