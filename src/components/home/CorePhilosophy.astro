---
import data from '../../data/home/corePhilosophy.json';

const { eyebrow, heading, description, quotes, values } = data;
const headingLines = heading.split('\n');
---

<section
  class="px-6 md:px-16 py-section bg-ink-900 text-ink-50"
  aria-labelledby="philosophy-heading"
>
  <p class="reveal text-eyebrow">{eyebrow}</p>
  <div class="reveal grid grid-cols-1 md:grid-cols-[250px_1fr] gap-0 md:gap-10">
    <div class="grid md:block grid-cols-2 md:grid-cols-1">
      <h2 id="philosophy-heading" class="text-heading mb-4">
        {
          headingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h2>
      <p class="text-ink-400">{description}</p>
    </div>

    <div class="border border-ink-700">
      <!-- Values -->
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-8 p-8 md:p-10">
        {
          values.map(({ title, body }) => (
            <div>
              <dt class="text-2xl font-black text-ink-50 tracking-[-0.03em] leading-[1.05] mb-3">
                {title}
              </dt>
              <dd class="text-sm leading-relaxed text-ink-400 max-w-sm">
                {body}
              </dd>
            </div>
          ))
        }
      </dl>

      <!-- Quotes — at the bottom -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-ink-700">
        {
          quotes.map(({ text, attribution }) => (
            <div class="p-8 md:p-10 bg-ink-900">
              <p class="text-lg md:text-xl font-black tracking-[-0.02em] leading-snug text-ink-100 mb-2">
                &ldquo;{text}&rdquo;
              </p>
              <p class="text-xs text-ink-500 italic">{attribution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
