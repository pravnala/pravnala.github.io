---
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';
import data from '../../data/home/corePhilosophy.json';

const { eyebrow, heading, description, quotes, values, nudge } = data;
const headingLines = heading.split('\n');
---

<section
  class="px-6 md:px-16 py-section bg-ink-50 text-ink-900"
  aria-labelledby="philosophy-heading"
>
  <p class="reveal text-eyebrow">{eyebrow}</p>
  <div class="reveal grid grid-cols-1 lg:grid-cols-[250px_1fr] gap-0 md:gap-10">
    <div class="grid md:block grid-cols-2 md:grid-cols-1">
      <h2 id="philosophy-heading" class="text-heading mb-4">
        {
          headingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h2>
      <p class="text-ink-500">{description}</p>
    </div>

    <div class="border-3 border-ink-400/30 bg-ink-600/30">
      <!-- Values -->
      <dl class="grid grid-cols-1 lg:grid-cols-2 gap-8 p-8 md:p-10">
        {
          values.map(({ title, body }) => (
            <div>
              <dt class="text-2xl font-black text-ink-800 tracking-[-0.03em] leading-[1.05] mb-3">
                {title}
              </dt>
              <dd class="text-sm leading-relaxed opacity-60 max-w-sm">
                {body}
              </dd>
            </div>
          ))
        }
      </dl>

      <!-- Quotes — at the bottom -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-px">
        {
          quotes.map(({ text, attribution }) => (
            <div class="p-8 md:p-10 bg-ink-300">
              <p class="text-lg md:text-xl font-black tracking-[-0.02em] leading-snug text-ink-700 mb-2">
                &ldquo;{text}&rdquo;
              </p>
              <p class="text-[13px] text-ink-700 italic">{attribution}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Closing nudge -->
  {
    nudge && (
      <div class="reveal mt-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 border-t border-ink-400/30 pt-10">
        <p class="text-sm md:text-base text-ink-500 max-w-prose">
          {nudge.text}
        </p>
        <Button
          variant="primary"
          href={nudge.buttonHref}
          class="shrink-0 inline-flex gap-2"
        >
          {nudge.buttonLabel}
          <BtnArrow />
        </Button>
      </div>
    )
  }
</section>
