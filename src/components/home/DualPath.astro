---
import Button from '../common/Button.astro';

const webDevYears = new Date().getFullYear() - 2000;
const fmaYears = new Date().getFullYear() - 2010;
---

<section class="grid grid-cols-1 md:grid-cols-2 w-full">
  {/* Dev_Path */}
  <div
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-surface text-ink no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-surface-hover"
    aria-label="Explore web development work"
  >
    <span class="reveal text-eyebrow text-ink-subtle">Dev</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Web<br />Development
      </h2>
      <p class="max-w-xs text-ink-muted mb-8">
        <!-- {webDevYears} years building digital products. From architecture to deployment
        — full-stack, client-focused, results-driven. -->
        {webDevYears} years of coding and building for the web.
      </p>
      <Button variant="primary" href="/work" class="inline-flex gap-2">
        View Work
        <span class="cta-arrow">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </Button>
    </div>
  </div>

  {/* Arnis_Path */}
  <div
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-canvas text-ink no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-surface-hover"
    aria-label="Explore Arnis martial arts instruction"
  >
    <span class="reveal text-eyebrow text-ink-subtle">FMA</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Filipino<br />Martial Arts
      </h2>
      <p class="text-ink-muted max-w-xs mb-8">
        {fmaYears} years of practice and teaching Lapunti Arnis de Abanico.
      </p>
      <Button variant="secondary" href="/work" class="inline-flex gap-2">
        Explore Arnis
        <span class="cta-arrow">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </Button>
    </div>
  </div>
</section>
