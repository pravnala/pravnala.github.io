---
import AnimatedSection from '../ui/AnimatedSection.astro';
---

<AnimatedSection animation="fade-in" delay={100}>
  <section class="grid grid-cols-1 md:grid-cols-2 w-full">
    {/* Dev_Path — dark block */}
    <a
      href="/work"
      class="group relative flex flex-col justify-between p-10 md:p-16 min-h-[28rem] bg-[var(--color-ink)] text-[var(--color-paper)] no-underline overflow-hidden transition-opacity duration-300 hover:opacity-90"
      aria-label="Explore web development work"
    >
      <span class="text-xs font-bold tracking-[0.2em] uppercase opacity-60">Dev</span>
      <div>
        <h2 class="text-5xl md:text-6xl font-black tracking-[-0.04em] leading-[1.05] mb-4">
          Web<br />Development
        </h2>
        <p class="text-sm md:text-base opacity-70 max-w-xs leading-relaxed mb-8">
          20+ years building digital products. From architecture to deployment — full-stack, client-focused, results-driven.
        </p>
        <span class="inline-flex items-center gap-2 text-sm font-bold tracking-[0.1em] uppercase border-b border-[var(--color-paper)] pb-0.5 group-hover:gap-4 transition-all duration-300">
          View Work
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </a>

    {/* Arnis_Path — light block */}
    <a
      href="/arnis"
      class="group relative flex flex-col justify-between p-10 md:p-16 min-h-[28rem] bg-[var(--color-paper)] text-[var(--color-ink)] no-underline overflow-hidden border border-[var(--color-ink)] transition-opacity duration-300 hover:opacity-80"
      aria-label="Explore Arnis martial arts instruction"
    >
      <span class="text-xs font-bold tracking-[0.2em] uppercase opacity-40">Arnis</span>
      <div>
        <h2 class="text-5xl md:text-6xl font-black tracking-[-0.04em] leading-[1.05] mb-4">
          Martial<br />Arts
        </h2>
        <p class="text-sm md:text-base opacity-60 max-w-xs leading-relaxed mb-8">
          16 years of Lapunti Arnis de Abanico mastery. Seminars, training, and instruction for students and organizations.
        </p>
        <span class="inline-flex items-center gap-2 text-sm font-bold tracking-[0.1em] uppercase border-b border-[var(--color-ink)] pb-0.5 group-hover:gap-4 transition-all duration-300">
          Explore Arnis
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </div>
    </a>
  </section>
</AnimatedSection>
