---
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';

const webDevYears = new Date().getFullYear() - 2000;
const fmaYears = new Date().getFullYear() - 2010;
---

<section class="grid grid-cols-1 md:grid-cols-2 w-full">
  {/* Dev_Path */}
  <div
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-ink-700 text-ink-50 no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-ink-600"
    aria-label="Explore web development work"
  >
    <span class="reveal text-eyebrow">Dev</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Web<br />Development
      </h2>
      <p class="max-w-xs text-ink-300 mb-8">
        {webDevYears} years of coding and building for the web.
      </p>
      <Button variant="primary" href="/work" class="inline-flex gap-2">
        View Work
        <BtnArrow />
      </Button>
    </div>
  </div>

  {/* Arnis_Path */}
  <div
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-ink-900 text-ink-50 no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-ink-800"
    aria-label="Explore Arnis martial arts instruction"
  >
    <span class="reveal text-eyebrow">FMA</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Filipino<br />Martial Arts
      </h2>
      <p class="text-ink-300 max-w-xs mb-8">
        {fmaYears} years of practice and teaching Lapunti Arnis de Abanico.
      </p>
      <Button variant="secondary" href="/work" class="inline-flex gap-2">
        Explore Arnis
        <BtnArrow />
      </Button>
    </div>
  </div>
</section>
