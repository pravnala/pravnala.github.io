---

---

<section class="grid grid-cols-1 md:grid-cols-2 w-full">
  {/* Dev_Path */}
  <div
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-surface text-ink no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-surface-hover "
    aria-label="Explore web development work"
  >
    <span class="reveal text-xs font-bold tracking-[0.2em] uppercase text-ink-subtle" style="animation-delay: 200ms;"
      >Dev</span
    >
    <div>
      <h2
        class="reveal text-5xl md:text-6xl font-black tracking-[-0.04em] leading-[1.05] mb-4"
        style="animation-delay: 400ms;"
      >
        Web<br />Development
      </h2>
      <p
        class="reveal text-sm md:text-base text-ink-muted max-w-xs leading-relaxed mb-8"
        style="animation-delay: 600ms;"
      >
        20+ years building digital products. From architecture to deployment —
        full-stack, client-focused, results-driven.
      </p>
      <span
        class="reveal cta-link inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase pb-1 mt-1 transition-all duration-300 group-hover:bg-ink group-hover:text-canvas px-3 py-1.5 -ml-3 border border-transparent group-hover:border-ink rounded-sm"
        style="animation-delay: 800ms;"
        >
        View Work
        <span class="cta-arrow">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </span>
    </div>
  </div>

  {/* Arnis_Path */}
  <div    
    class="group relative flex flex-col justify-between p-10 md:p-16 min-h-112 bg-surface text-ink no-underline overflow-hidden transition-[background-color,transform] duration-500 ease-in-out hover:bg-surface-hover"
    aria-label="Explore Arnis martial arts instruction"
  >
    <span class="text-xs font-bold tracking-[0.2em] uppercase text-ink-subtle"
      >Arnis</span
    >
    <div>
      <h2
        class="text-5xl md:text-6xl font-black tracking-[-0.04em] leading-[1.05] mb-4"
      >
        Filipino<br />Martial Arts
      </h2>
      <p
        class="text-sm md:text-base text-ink-muted max-w-xs leading-relaxed mb-8"
      >
        16 years of Lapunti Arnis de Abanico mastery. Seminars, training, and
        instruction for students and organizations.
      </p>
      <span
        class="cta-link inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase pb-1 mt-1 transition-all duration-300 group-hover:bg-ink group-hover:text-canvas px-3 py-1.5 -ml-3 border border-transparent group-hover:border-ink rounded-sm"
      >
        Explore Arnis
        <span class="cta-arrow">
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </span>
    </div>
  </div>
</section>
