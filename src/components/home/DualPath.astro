---
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';
import data from '../../data/home/dualPath.json';

const webDevYears = new Date().getFullYear() - 2000;
const fmaPracticeYears = new Date().getFullYear() - 2010;
const fmaTeachingYears = new Date().getFullYear() - 2015;

const dev = data.dev;
const arnis = data.arnis;

const devHeadingLines = dev.heading.split('\n');
const arnisHeadingLines = arnis.heading.split('\n');

const devSummary = dev.summary.replace('{webDevYears}', String(webDevYears));
const arnisSummary = arnis.summary
  .replace('{fmaPracticeYears}', String(fmaPracticeYears))
  .replace('{fmaTeachingYears}', String(fmaTeachingYears));

const resolveStats = (stats: { value: string; label: string }[]) =>
  stats.map((s) => ({
    ...s,
    value: s.value
      .replace('{webDevYears}', String(webDevYears))
      .replace('{fmaPracticeYears}', String(fmaPracticeYears))
      .replace('{fmaTeachingYears}', String(fmaTeachingYears)),
  }));

const devStats = resolveStats(dev.stats);
const arnisStats = resolveStats(arnis.stats);
---

<section class="grid grid-cols-1 xl:grid-cols-2 w-full">
  {/* Dev_Path */}
  <div
    class="group relative px-6 md:px-16 py-16 min-h-112 bg-ink-600 no-underline overflow-hidden transition duration-500 ease-in-out hover:bg-ink-500"
    aria-label="Explore web development work"
  >
    <span class="reveal text-eyebrow mb-8 block text-ink-300"
      >{dev.eyebrow}</span
    >
    <div class="reveal">
      <h2 class="text-heading mb-4">
        {
          devHeadingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h2>
      <div class="max-w-lg text-ink-300 mb-8 space-y-3">
        <p
          class="text-ink-50 group-hover:text-ink-50 transition-opacity duration-500 ease-in-out"
        >
          {devSummary}
        </p>
        <p class="text-ink-50/65 transition-opacity duration-500 ease-in-out">
          {dev.description}
        </p>
      </div>

      <!-- Stats -->
      <div
        class="reveal flex gap-8 mb-8 border-t border-ink-500 group-hover:border-ink-400 duration-500 ease-in-out pt-6"
      >
        {
          devStats.map(({ value, label }) => (
            <div>
              <p class="text-4xl md:text-5xl font-black tracking-[-0.04em] leading-none mb-1">
                {value}
              </p>
              <p class="text-[10px] font-bold tracking-[0.15em] uppercase text-ink-400 group-hover:text-ink-300 transition-colors duration-500">
                {label}
              </p>
            </div>
          ))
        }
      </div>

      <!-- Buttons -->
      <div class="reveal flex flex-wrap items-center gap-4">
        <Button
          variant="primary"
          href={dev.primaryButton.href}
          class="inline-flex justify-between sm:justify-around gap-0 sm:gap-2 w-full sm:w-auto"
        >
          {dev.primaryButton.label}
          <BtnArrow />
        </Button>
        <Button
          variant="secondary"
          href={dev.secondaryButton.href}
          class="inline-flex justify-between sm:justify-around gap-0 sm:gap-2 w-full sm:w-auto"
        >
          {dev.secondaryButton.label}
          <BtnArrow />
        </Button>
      </div>
    </div>
  </div>

  {/* Arnis_Path */}
  <div
    class="group relative px-6 md:px-16 py-16 min-h-112 bg-ink-800 no-underline overflow-hidden transition duration-500 ease-in-out hover:bg-ink-700"
    aria-label="Explore Arnis martial arts instruction"
  >
    <span class="reveal text-eyebrow mb-8 block">{arnis.eyebrow}</span>
    <div class="reveal">
      <h2 class="text-heading mb-4">
        {
          arnisHeadingLines.map((line, i) => (
            <>
              {i > 0 && <br />}
              {line}
            </>
          ))
        }
      </h2>
      <div
        class="max-w-lg text-ink-300 mb-8 space-y-3 group-hover:text-ink-100 transition-colors duration-500 ease-in-out"
      >
        <p
          class="text-ink-50/65 group-hover:text-ink-50/80 transition-opacity duration-500 ease-in-out"
        >
          {arnisSummary}
        </p>
        <p
          class="text-ink-50/40 group-hover:text-ink-50/50 transition-opacity duration-500 ease-in-out"
        >
          {arnis.description}
        </p>
      </div>

      <!-- Stats -->
      <div
        class="reveal flex gap-8 mb-8 border-t border-ink-700 group-hover:border-ink-600 duration-500 ease-in-out pt-6"
      >
        {
          arnisStats.map(({ value, label }) => (
            <div>
              <p class="text-4xl md:text-5xl font-black tracking-[-0.04em] leading-none mb-1">
                {value}
              </p>
              <p class="text-[10px] font-bold tracking-[0.15em] uppercase text-ink-500 group-hover:text-ink-400 transition-colors duration-500">
                {label}
              </p>
            </div>
          ))
        }
      </div>

      <!-- Buttons -->
      <div class="reveal flex flex-wrap items-center gap-4">
        <Button
          variant="secondary"
          href={arnis.primaryButton.href}
          class="inline-flex justify-between sm:justify-around gap-0 sm:gap-2 w-full sm:w-auto"
        >
          {arnis.primaryButton.label}
          <BtnArrow />
        </Button>
        <Button
          variant="primary"
          href={arnis.secondaryButton.href}
          class="inline-flex justify-between sm:justify-around gap-0 sm:gap-2 w-full sm:w-auto border-ink-600! hover:border-ink-900!"
        >
          {arnis.secondaryButton.label}
          <BtnArrow />
        </Button>
      </div>
    </div>
  </div>
</section>
