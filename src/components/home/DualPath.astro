---
import Button from '../common/Button.astro';
import BtnArrow from '../common/BtnArrow.astro';

const webDevYears = new Date().getFullYear() - 2000;
const fmaPracticeYears = new Date().getFullYear() - 2010;
const fmaTeachingYears = new Date().getFullYear() - 2015;
---

<section class="grid grid-cols-1 md:grid-cols-2 w-full">
  {/* Dev_Path */}
  <div
    class="group relative flex flex-col justify-between px-6 md:px-16 py-16 min-h-112 bg-ink-700 text-ink-50 no-underline overflow-hidden transition duration-500 ease-in-out hover:bg-ink-600"
    aria-label="Explore web development work"
  >
    <span class="reveal text-eyebrow">Dev</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Web<br />Development
      </h2>
      <div class="max-w-sm text-ink-300 mb-8 space-y-3">
        <p class="text-ink-50/55 group-hover:text-ink-50/80 transition-opacity duration-500 ease-in-out">
          {webDevYears} years of coding and building for the web.           
        </p>
        <p class="text-ink-50/30 group-hover:text-ink-50/50 transition-opacity duration-500 ease-in-out">
          From legacy systems to modern stacks and frameworks. Now prefers (and enjoys) building projects on Astro and Svelte.
          There's no web project that can't be built better (and with much less
          headache) than on Astro or Svelte, and you can't convince me otherwise
          (heh!).
        </p>
      </div>
      <Button variant="primary" href="/work" class="inline-flex gap-2">
        View Work
        <BtnArrow />
      </Button>
    </div>
  </div>

  {/* Arnis_Path */}
  <div
    class="group relative flex flex-col justify-between px-6 md:px-16 py-16 min-h-112 bg-ink-900 text-ink-50 no-underline overflow-hidden transition duration-500 ease-in-out hover:bg-ink-600"
    aria-label="Explore Arnis martial arts instruction"
  >
    <span class="reveal text-eyebrow">FMA</span>
    <div class="reveal" style="animation-delay: 400ms;">
      <h2 class="text-heading mb-4">
        Filipino<br />Martial Arts
      </h2>
      <div class="max-w-sm text-ink-300 mb-8 space-y-3 group-hover:text-ink-100 transition-colors duration-500 ease-in-out">        
        <p class="text-ink-50/65 group-hover:text-ink-50/80 transition-opacity duration-500 ease-in-out">
          {fmaPracticeYears} years of practice and {fmaTeachingYears} years of teaching
          Lapunti Arnis de Abanico.
        </p>
        <p class="text-ink-50/40 group-hover:text-ink-50/50 transition-opacity duration-500 ease-in-out">
           Wandered the halls of different martial art schools prior to all that. Found the art that I will practice towards my old age in Lapunti Arnis De Abanico. 
           Now on a path towards what my teachers have set me on to, and which they themselves have embarked on: finding my own Lapunti.  
        </p>
      </div>
      <div class="max-w-sm text-ink-200 mb-8 space-y-3">
      </div>
      <Button variant="secondary" href="/work" class="inline-flex gap-2">
        Explore Arnis
        <BtnArrow />
      </Button>
    </div>
  </div>
</section>
