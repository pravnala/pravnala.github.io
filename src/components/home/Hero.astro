---
import { Image } from 'astro:assets';
import pravnalaSketch from '../../assets/images/pravnala-sketch-alpha.png';
import Button from '../common/Button.astro';
import data from '../../data/home/hero.json';

const { name, roles, buttons } = data;
---

<section
  id="hero"
  class="relative min-h-screen justify-center overflow-hidden bg-ink-50 grid grid-cols-2"
  style="clip-path: inset(0);"
>
  <!-- Background Image -->
  <div class="fixed top-[80px] bottom-[40px] inset-x-0 pointer-events-none">
    <Image
      src={pravnalaSketch}
      alt="pravnala sketch"
      class="h-full w-full object-contain"
      widths={[640, 1024, 1600]}
      sizes="(max-width: 1023px) 100vw, 70vw"
      loading="eager"
      aria-hidden="true"
    />
  </div>

  <div class="px-5 md:px-20 py-16 grid place-items-center">
    <!-- Left Split Panel -->
  </div>

  <div class="bg-ink-950/80 p-5 lg:p-20 grid place-items-center">
    <div
      class="text-xl md:text-2xl lg:text-4xl xl:text-5xl 2xl:text-6xl font-black tracking-[-0.04em] leading-[1.05] mt-16 space-y-10 text-right text-ink-50"
    >
      <!-- Name -->
      <p
        class="animate-entrance text-eyebrow text-ink-300"
        style="animation-delay: 100ms;"
      >
        {name}
      </p>

      {
        roles.map((role, i) => (
          <div
            class={`animate-entrance${role.bold ? '' : ' font-normal'}`}
            style={`animation-delay: ${(i + 1) * 200}ms;`}
          >
            {role.text}
          </div>
        ))
      }

      <div class="pt-5 md:pt-10 md:mt-10 flex flex-wrap gap-4 justify-end">
        {
          buttons.map((btn, i) => (
            <Button
              href={btn.href}
              variant={btn.variant as 'primary' | 'secondary'}
              class="animate-entrance w-full lg:w-auto"
              style={`animation-delay: ${(i + 1) * 400}ms;`}
            >
              {btn.label}
            </Button>
          ))
        }
      </div>
    </div>
  </div>
</section>
