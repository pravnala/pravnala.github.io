---
import { Image } from 'astro:assets';
import pravnalaSketch from '../../assets/images/pravnala-sketch-alpha.png';
---

<section
  id="hero"
  class="relative min-h-screen justify-center overflow-hidden bg-ink grid grid-cols-2"
>
  <!-- Background Image -->
  <div class="absolute top-[80px] bottom-[40px] inset-x-0">
    <Image
      src={pravnalaSketch}
      alt="pravnala sketch"
      class="h-full w-full object-contain"
      widths={[640, 1024, 1600]}
      sizes="(max-width: 1023px) 100vw, 70vw"
      loading="eager"
      aria-hidden="true"
    />
  </div>

  <div class="px-5 md:px-20 py-16 grid place-items-center">
    <!-- Left Split Panel -->
  </div>
  <div class="bg-black/80 p-5 lg:p-20 grid place-items-center">
    <div
      class="text-xl md:text-2xl lg:text-4xl xl:text-5xl 2xl:text-6xl font-black tracking-[-0.04em] leading-[1.05] mt-16 space-y-10 text-right text-ink"
    >
      <div class="animate-entrance" style="animation-delay: 200ms;">
        Web Developer
      </div>
      <div class="animate-entrance" style="animation-delay: 400ms;">
        FMA Instructor
      </div>
      <div class="animate-entrance font-normal" style="animation-delay: 600ms;">
        IT Consultant
      </div>
      <div class="animate-entrance font-normal" style="animation-delay: 800ms;">
        Linux and Open Source Advocate
      </div>
      <div class="pt-5 md:pt-10 md:mt-10 flex flex-wrap gap-4 justify-end">
        <a
          href="/work"
          class:list={[
            'inline-block px-3 md:px-8 py-3 md:py-4 bg-canvas text-ink text-xs md:text-sm font-normal uppercase tracking-widest border-2 border-canvas',
            'animate-entrance transition-colors duration-300 ease-in-out',
            'hover:bg-ink-muted hover:text-canvas',
            'focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-paper',
            'text-center w-full lg:w-auto',
          ]}
          aria-label="View My Work"
          style="animation-delay: 400ms;"
        >
          Dev Work
        </a>
        <a
          href="/arnis"
          class:list={[
            'inline-block px-3 md:px-8 py-3 md:py-4 bg-canvas text-ink text-xs md:text-sm font-normal uppercase tracking-widest border-2 border-canvas',
            'animate-entrance transition-colors duration-300 ease-in-out',
            'hover:bg-ink-muted hover:text-canvas',
            'focus-visible:outline focus-visible:outline-offset-2 focus-visible:outline-paper',
            'text-center w-full lg:w-auto',
          ]}
          aria-label="Arnis Training"
          style="animation-delay: 600ms;"
        >
          FMA Training
        </a>
      </div>
    </div>
  </div>
</section>
