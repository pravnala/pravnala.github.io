---
import { Image } from 'astro:assets';
import pravnalaSketch from '../../assets/images/pravnala-sketch-alpha.png';
import Button from '../common/Button.astro';
---

<section
  id="hero"
  class="relative min-h-screen justify-center overflow-hidden bg-ink-50 grid grid-cols-2"
  style="clip-path: inset(0);"
>
  <!-- Background Image -->
  <div class="fixed top-[80px] bottom-[40px] inset-x-0 pointer-events-none">
    <Image
      src={pravnalaSketch}
      alt="pravnala sketch"
      class="h-full w-full object-contain"
      widths={[640, 1024, 1600]}
      sizes="(max-width: 1023px) 100vw, 70vw"
      loading="eager"
      aria-hidden="true"
    />
  </div>

  <div class="px-5 md:px-20 py-16 grid place-items-center">
    <!-- Left Split Panel -->
  </div>
  <div class="bg-ink-950/80 p-5 lg:p-20 grid place-items-center">
    <div
      class="text-xl md:text-2xl lg:text-4xl xl:text-5xl 2xl:text-6xl font-black tracking-[-0.04em] leading-[1.05] mt-16 space-y-10 text-right text-ink-50"
    >
      <div class="animate-entrance" style="animation-delay: 200ms;">
        Web Developer
      </div>
      <div class="animate-entrance" style="animation-delay: 400ms;">
        FMA Instructor
      </div>
      <div class="animate-entrance font-normal" style="animation-delay: 600ms;">
        IT Consultant
      </div>
      <div class="animate-entrance font-normal" style="animation-delay: 800ms;">
        Linux and Open Source Advocate
      </div>
      <div class="pt-5 md:pt-10 md:mt-10 flex flex-wrap gap-4 justify-end">
        <Button
          href="/dev"
          class="animate-entrance w-full lg:w-auto"
          style="animation-delay: 400ms;">Dev Work</Button
        >
        <Button
          href="/arnis"
          class="animate-entrance w-full lg:w-auto"
          style="animation-delay: 800ms;"
          variant="secondary">FMA Training</Button
        >
      </div>
    </div>
  </div>
</section>
