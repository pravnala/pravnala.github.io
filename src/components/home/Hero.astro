---
import AnimatedSection from '../ui/AnimatedSection.astro';
---

<AnimatedSection animation="fade-up">
  <section class="relative min-h-screen flex flex-col justify-center px-6 py-24 overflow-hidden bg-[var(--color-ink)]">

    <!-- Text-over-image masking headline -->
    <div class="max-w-6xl mx-auto w-full">
      <h1
        class="text-[clamp(4rem,15vw,14rem)] font-black leading-none tracking-tighter uppercase select-none"
        style="
          background-image: url('https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1600&q=80&auto=format&fit=crop');
          background-size: cover;
          background-position: center;
          -webkit-background-clip: text;
          background-clip: text;
          -webkit-text-fill-color: transparent;
          color: transparent;
          filter: contrast(1.2);
        "
        aria-label="Code. Discipline. Mastery."
      >
        Code.<br />Discipline.<br />Mastery.
      </h1>

      <!-- Positioning statement -->
      <p class="mt-8 text-[var(--color-paper)] text-lg md:text-xl font-bold tracking-tight max-w-xl leading-snug">
        Alvin Penaflor — 20+ years building for the web.<br />
        16 years teaching Lapunti Arnis de Abanico.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/work"
          class="inline-block px-8 py-4 bg-[var(--color-paper)] text-[var(--color-ink)] font-black text-sm uppercase tracking-widest transition-opacity hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-paper)]"
          aria-label="View My Work"
        >
          View My Work
        </a>
        <a
          href="/arnis"
          class="inline-block px-8 py-4 border-2 border-[var(--color-paper)] text-[var(--color-paper)] font-black text-sm uppercase tracking-widest transition-opacity hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-paper)]"
          aria-label="Arnis Training"
        >
          Arnis Training
        </a>
      </div>
    </div>

  </section>
</AnimatedSection>
