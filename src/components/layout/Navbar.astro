---
import navLinks from '../../data/navLinks.json';

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="site-header fixed top-0 left-0 right-0 z-60">
  <div class="section-container h-16 py-0 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-black transition-colors duration-500 ease-out text-ink-50 hover:text-ink-300 group"
      aria-label="pra>nala — Home"
    >
      pra<span
        class="text-ink-300/80 transition-transform duration-500 ease-out group-hover:text-ink-50"
        >v</span
      >nala
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-8">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? 'page' : undefined}
            class:list={[
              'text-xs font-bold uppercase tracking-[0.12em] transition-colors duration-200 ease-out hover:text-ink-50',
              isActive(href)
                ? 'text-ink-50'
                : 'text-ink-300 hover-underline-sweep',
            ]}
          >
            {label}
          </a>
        ))
      }
      <a
        href="https://github.com/pravnala"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
        class="text-ink-300 transition-colors duration-200 ease-out hover:text-ink-50 cursor-pointer"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path>
        </svg>
      </a>
    </nav>

    <!-- Right side: hamburger (mobile only) -->
    <button
      id="menu-toggle"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex md:hidden flex-col justify-center items-center w-9 h-9 gap-[5px] border border-ink-300/40 transition-opacity hover:opacity-60"
    >
      <span class="hamburger-bar bar-top block w-4 h-[2px] bg-current"></span>
      <span class="hamburger-bar bar-mid block w-4 h-[2px] bg-current"></span>
      <span class="hamburger-bar bar-bottom block w-4 h-[2px] bg-current"
      ></span>
    </button>
  </div>
</header>

<!-- Spacer so page content isn't hidden under fixed header -->
<!-- <div class="h-16" aria-hidden="true"></div> -->

<!-- Fullscreen mobile menu overlay (sibling to header) -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="mobile-menu fixed inset-0 z-50 flex flex-col items-center justify-center"
  style="background: rgba(10,10,10,0.95); backdrop-filter: blur(var(--blur-glass-heavy));"
>
  <nav aria-label="Mobile navigation">
    <ul class="flex flex-col items-center gap-8">
      {
        navLinks.map(({ href, label }, i) => (
          <li style={`--link-delay: ${i * 100}ms`}>
            <a
              href={href}
              aria-current={isActive(href) ? 'page' : undefined}
              class:list={[
                'text-2xl tracking-[-0.04em] transition-colors duration-300 ease-out hover:text-ink-300',
                isActive(href) ? 'text-ink-300/70' : 'text-ink-50',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
      <li style={`--link-delay: ${navLinks.length * 100}ms`}>
        <a
          href="https://github.com/pravnala"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub profile"
          class="inline-flex text-ink-50 transition-colors duration-300 ease-out hover:text-ink-300 cursor-pointer"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
        </a>
      </li>
    </ul>
  </nav>
</div>

<script>
  function initMenu(): void {
    const toggle = document.getElementById(
      'menu-toggle'
    ) as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;

    if (!toggle || !menu) return;

    function getFocusable(): HTMLElement[] {
      return Array.from(
        menu!.querySelectorAll<HTMLElement>(
          'a, button, [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute('disabled'));
    }

    function openMenu(): void {
      menu!.classList.remove('is-closing');
      menu!.classList.add('is-open');
      toggle!.setAttribute('aria-expanded', 'true');
      toggle!.setAttribute('aria-label', 'Close navigation menu');
      document.body.style.overflow = 'hidden';
      const focusable = getFocusable();
      focusable[0]?.focus();
    }

    function closeMenu(): void {
      menu!.classList.add('is-closing');
      menu!.classList.remove('is-open');
      toggle!.setAttribute('aria-expanded', 'false');
      toggle!.setAttribute('aria-label', 'Open navigation menu');
      document.body.style.overflow = '';
      menu!.addEventListener(
        'transitionend',
        () => {
          menu!.classList.remove('is-closing');
        },
        { once: true }
      );
    }

    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    // Close on nav link click (with animation)
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Escape key closes menu
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (
        e.key === 'Escape' &&
        toggle.getAttribute('aria-expanded') === 'true'
      ) {
        closeMenu();
        toggle.focus();
      }
    });

    // Focus trap
    menu.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'Tab') return;
      const focusable = getFocusable();
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }

  function initScrollEffect(): void {
    const header = document.querySelector<HTMLElement>('header.site-header');
    const THRESHOLD = 80;
    const reduced = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    if (!header) return;

    function update(): void {
      const scrolled = window.scrollY > THRESHOLD;
      header!.classList.toggle('is-scrolled', scrolled);
      if (reduced) header!.style.transition = 'none';
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  initMenu();
  initScrollEffect();
  document.addEventListener('astro:after-swap', initMenu);
  document.addEventListener('astro:after-swap', initScrollEffect);
</script>
