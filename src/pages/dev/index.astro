---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerHero from '../../components/layout/InnerHero.astro';
import CaseStudies from '../../components/work/CaseStudies.astro';
import ExperienceTable from '../../components/work/ExperienceTable.astro';
import TechStack from '../../components/work/TechStack.astro';
import ValueProps from '../../components/work/ValueProps.astro';
import Testimonials from '../../components/work/Testimonials.astro';
import GoodFit from '../../components/work/GoodFit.astro';
import WorkCTA from '../../components/work/WorkCTA.astro';
import heroData from '../../data/dev/hero.json';

const webDevYears = new Date().getFullYear() - 2000;
const heroDescription = heroData.description.replace(
  '{years}',
  String(webDevYears)
);
---

<BaseLayout
  title="Dev"
  description={`${webDevYears}+ years designing and developing modern, high-performance websites and web applications. Currently specializing in Astro, Svelte/SvelteKit, Tailwind CSS, and cloud platforms.`}
>
  <InnerHero title={heroData.title} description={heroDescription} />
  <CaseStudies />
  <ExperienceTable />
  <TechStack />
  <ValueProps />
  <Testimonials />
  <GoodFit />
  <WorkCTA />
</BaseLayout>
