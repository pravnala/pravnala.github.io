---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import placeholderImage from '../../assets/images/case-study-placeholder.png';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries
    .filter((entry) => entry.data.hasDetailPage)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const {
  title,
  projectContext,
  problem,
  solution,
  outcome,
  technologies,
  coverImage,
} = entry.data;
const { Content } = await render(entry);

// Dynamically import cover image if specified, otherwise use placeholder
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/case-studies/*.*'
);
let resolvedImage = placeholderImage;
if (coverImage && images[coverImage]) {
  const mod = await images[coverImage]();
  resolvedImage = mod.default;
}
---

<BaseLayout title={`${title} — Alvin Penaflor`}>
  <main class="max-w-4xl mx-auto px-6 py-24 md:py-32">
    <!-- Back link -->
    <a
      href="/dev"
      class="inline-block text-xs font-bold tracking-[0.2em] uppercase opacity-50 hover:opacity-100 transition-opacity duration-500 mb-16"
    >
      ← Back to Dev
    </a>

    <!-- Title -->
    <header class="mb-16 md:mb-24 border-b-2 border-ink-50 pb-12">
      <h1
        class="text-5xl md:text-7xl font-black tracking-[-0.04em] leading-[1.05]"
      >
        {title}
      </h1>
    </header>

    <!-- Cover image -->
    <div class="mb-16 md:mb-24 overflow-hidden">
      <Image
        src={resolvedImage}
        alt={`${title} project screenshot`}
        class="w-full h-auto object-cover opacity-80"
        widths={[800, 1200]}
        sizes="(max-width: 768px) 100vw, 800px"
      />
    </div>

    <!-- Case study sections -->
    <div class="space-y-16 md:space-y-20">
      <!-- Project Context -->
      <section aria-labelledby="context-heading">
        <h2
          id="context-heading"
          class="text-xs font-bold tracking-[0.2em] uppercase mb-4 opacity-50"
        >
          Project Context
        </h2>
        <p class="text-lg leading-relaxed">{projectContext}</p>
      </section>

      <!-- Problem -->
      {
        problem && (
          <section aria-labelledby="problem-heading">
            <h2
              id="problem-heading"
              class="text-xs font-bold tracking-[0.2em] uppercase mb-4 opacity-50"
            >
              Problem
            </h2>
            <p class="text-lg leading-relaxed">{problem}</p>
          </section>
        )
      }

      <!-- Solution -->
      {
        solution && (
          <section aria-labelledby="solution-heading">
            <h2
              id="solution-heading"
              class="text-xs font-bold tracking-[0.2em] uppercase mb-4 opacity-50"
            >
              Solution
            </h2>
            <p class="text-lg leading-relaxed">{solution}</p>
          </section>
        )
      }

      <!-- Outcome -->
      {
        outcome && (
          <section aria-labelledby="outcome-heading">
            <h2
              id="outcome-heading"
              class="text-xs font-bold tracking-[0.2em] uppercase mb-4 opacity-50"
            >
              Outcome
            </h2>
            <p class="text-lg leading-relaxed">{outcome}</p>
          </section>
        )
      }

      <!-- Technologies -->
      <section aria-labelledby="tech-heading">
        <h2
          id="tech-heading"
          class="text-xs font-bold tracking-[0.2em] uppercase mb-4 opacity-50"
        >
          Technologies
        </h2>
        <ul class="flex flex-wrap gap-2" role="list">
          {
            technologies.map((tech) => (
              <li class="border border-ink-50 px-3 py-1 text-xs font-bold tracking-widest uppercase">
                {tech}
              </li>
            ))
          }
        </ul>
      </section>

      <!-- Extended body content -->
      {
        Content && (
          <section
            aria-label="Full case study"
            class="border-t border-ink-600 pt-12 space-y-8"
          >
            <div class="case-study-content">
              <Content />
            </div>
          </section>
        )
      }
    </div>

    <!-- Bottom back link -->
    <a
      href="/dev"
      class="inline-block text-xs font-bold tracking-[0.2em] uppercase opacity-50 hover:opacity-100 transition-opacity duration-500 mt-20"
    >
      ← Back to Dev
    </a>
  </main>
</BaseLayout>
