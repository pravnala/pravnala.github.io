---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return allPosts
    .filter((entry) => entry.data.draft !== true)
    .map((entry) => ({
      params: { slug: entry.id.replace(/\.[^.]+$/, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { title, publishDate, category } = entry.data;
const { Content } = await render(entry);

const categoryLabel = category === 'tech' ? 'Tech' : 'Martial Arts';

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Alvin Penaflor`}>
  <main class="max-w-3xl mx-auto px-6 py-24 md:py-32">

    <!-- Back link -->
    <a
      href="/blog"
      class="inline-block text-xs font-bold tracking-[0.2em] uppercase opacity-50 hover:opacity-100 transition-opacity duration-200 mb-16"
    >
      ← Back to Blog
    </a>

    <!-- Post header -->
    <header class="mb-16 border-b-2 border-ink pb-12">
      <div class="flex items-center gap-4 mb-6">
        <span class="text-xs font-bold tracking-[0.2em] uppercase border border-ink px-3 py-1">
          {categoryLabel}
        </span>
        <time
          datetime={publishDate.toISOString()}
          class="text-xs tracking-[0.15em] uppercase opacity-50"
        >
          {formattedDate}
        </time>
      </div>
      <h1 class="text-4xl md:text-6xl font-black tracking-[-0.04em] leading-[1.05]">
        {title}
      </h1>
    </header>

    <!-- Body content -->
    <article class="prose prose-lg max-w-none">
      <Content />
    </article>

  </main>
</BaseLayout>
