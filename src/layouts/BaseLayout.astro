---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const webDevYears = new Date().getFullYear() - 2000;
const fmaYears = new Date().getFullYear() - 2010;
const defaultDescription = `${webDevYears} years building for the web. ${fmaYears} years teaching Lapunti Arnis de Abanico. Precision, discipline, and craftsmanship in everything.`;
const { title, description = defaultDescription, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>pravnala | {title}</title>
    {description && <meta name="description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260612"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260612" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260612" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260612"
    />
    <meta name="apple-mobile-web-app-title" content="Pravnala" />
    <link rel="manifest" href="/site.webmanifest?v=20260612" />

    <!-- Anti-FOUC: site is permanently dark -->
    <script is:inline>
      document.documentElement.classList.add('dark');
    </script>

    <!-- Preload fonts -->
    <Font cssVariable="--font-outfit" preload />
    <Font cssVariable="--font-inter" preload />
    <!-- <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /> -->

    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-dvh">
    <Navbar />
    <main class="grow">
      <slot />
    </main>
    <Footer />
    <script>
      function initReveal() {
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('active');
          });
        }, observerOptions);
        document
          .querySelectorAll('.reveal')
          .forEach((el) => observer.observe(el));
      }

      // Runs on initial load and after every View Transition navigation
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
