---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const webDevYears = new Date().getFullYear() - 2000;
const fmaYears = new Date().getFullYear() - 2010;
const defaultDescription = `${webDevYears} years building for the web. ${fmaYears} years teaching Lapunti Arnis de Abanico. Precision, discipline, and craftsmanship in everything.`;
const { title, description = defaultDescription, ogImage } = Astro.props;

// JSON-LD for SEO
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Alvin Penaflor',
  url: 'https://pravnala.github.io/',
  hasOccupation: [
    {
      '@type': 'Occupation',
      name: 'IT Professional and Web Developer',
    },
    {
      '@type': 'Occupation',
      name: 'Filipino Martial Arts (FMA) Instructor',
      description: 'Lapunti Arnis De Abanico Instructor teaching at UP Diliman',
    },
  ],
};

// Open Graph
const siteUrl = "https://pravnala.github.io";
const ogImageUrl = `${siteUrl}/og-image.webp`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>pravnala | {title}</title>
    {description && <meta name="description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content="Alvin Penaflor | IT Professional, Web Developer & FMA Instructor" />
    <meta property="og:description" content="Explore my IT portfolio or join me for Lapunti Arnis De Abanico FMA training sessions." />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <link rel="canonical" href={siteUrl} />
    <meta name="theme-color" content="#111827" />
    <meta property="og:image:alt" content="Alvin Penaflor - Web Developer & FMA Instructor Portfolio" />
    <meta property="og:site_name" content="Pravnala" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon -->
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260612"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260612" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260612" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260612"
    />
    <meta name="apple-mobile-web-app-title" content="Pravnala" />
    <link rel="manifest" href="/site.webmanifest?v=20260612" />

    <!-- Anti-FOUC: site is permanently dark -->
    <script is:inline>
      document.documentElement.classList.add('dark');
    </script>

    <!-- Preload fonts -->
    <Font cssVariable="--font-outfit" preload />
    <Font cssVariable="--font-inter" preload />

    <!-- JSON-LD for SEO -->
    <script is:inline type="application/ld+json">
      {JSON.stringify(personSchema)}
    </script>

    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-dvh">
    <Navbar />
    <main class="grow">
      <slot />
    </main>
    <Footer />
    <script>
      function initReveal() {
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('active');
          });
        }, observerOptions);
        document
          .querySelectorAll('.reveal')
          .forEach((el) => observer.observe(el));
      }

      // Runs on initial load and after every View Transition navigation
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
