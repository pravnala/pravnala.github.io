---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import { SEO } from 'astro-seo';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const webDevYears = new Date().getFullYear() - 2000;
const fmaTeachingYears = new Date().getFullYear() - 2015;
const defaultDescription = `${webDevYears} years building for the web. ${fmaTeachingYears} years teaching Lapunti Arnis de Abanico. Precision, discipline, and craftsmanship in everything.`;
const { title, description = defaultDescription, ogImage } = Astro.props;

// JSON-LD for SEO
// const personSchema = {
//   '@context': 'https://schema.org',
//   '@type': 'Person',
//   name: 'Alvin Penaflor',
//   url: 'https://pravnala.github.io/',
//   hasOccupation: [
//     {
//       '@type': 'Occupation',
//       name: 'IT Professional and Web Developer',
//     },
//     {
//       '@type': 'Occupation',
//       name: 'Filipino Martial Arts (FMA) Instructor',
//       description: 'Lapunti Arnis De Abanico Instructor teaching at UP Diliman',
//     },
//   ],
// };

// Open Graph
const siteUrl = 'https://pravnala.github.io';
const ogImageUrl = `${siteUrl}/og-image.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- <Seo
      title={`pravnala | ${title}`}
      description={description}
      keywords={[
        'web developer',
        'web development',
        'website development',
        'IT consultant',
        'fma',
        'filipino martial arts',
        'arnis',
        'lapunti',
        'lapunti arnis de abanico',
        'arnis instructor',
        'arnis instruction',
      ]}
      themeColor="#060606"
      colorScheme="dark"
      robots="index, follow"
      facebook={{
        image: '/og-image.jpg',
        url: 'https://pravnala.github.io',
        type: 'website',
      }}
      twitter={{
        image: '/og-image.jpg',
        card: 'summary_large_image',
      }}
    /> -->

    <SEO
      title={`pravnala | ${title}`}
      description={description}
      openGraph={{
        basic: {
          title: 'Alvin Penaflor | Web Developer & FMA Instructor',
          type: 'website',
          image: '/og-image.jpg',
        },
        image: {
          type: 'image/jpeg',
          width: 1200,
          height: 630,
          alt: 'Alvin Penaflor | Web Developer & FMA Instructor',
        },
        optional: {
          siteName: 'Pravnala',
          locale: 'en_US',
        },
      }}
      twitter={{
        card: 'summary_large_image',
      }}
      extend={{
        meta: [{ name: 'theme-color', content: '#060606' }],
      }}
    />

    <!-- 
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="630" />

    <link rel="canonical" href={siteUrl} />
    
    <meta
      property="og:image:alt"
      content="Alvin Penaflor | Web Developer & FMA Instructor"
    />
    <meta property="og:site_name" content="Pravnala" />
    <meta property="og:locale" content="en_US" />
    -->

    <!-- Favicon / App Icon -->
    <link
      rel="icon"
      type="image/png"
      href="/favicon-96x96.png?v=20260612"
      sizes="96x96"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260612" />
    <link rel="shortcut icon" href="/favicon.ico?v=20260612" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=20260612"
    />
    <meta name="apple-mobile-web-app-title" content="Pravnala" />
    <link rel="manifest" href="/site.webmanifest?v=20260612" />

    <!-- Anti-FOUC: site is permanently dark -->
    <script is:inline>
      document.documentElement.classList.add('dark');
    </script>

    <!-- Preload fonts -->
    <Font cssVariable="--font-outfit" preload />
    <Font cssVariable="--font-inter" preload />

    <!-- JSON-LD for SEO -->
    <!-- <script is:inline type="application/ld+json">
      {JSON.stringify(personSchema)}
    </script> -->

    <ClientRouter />
  </head>
  <body class="flex flex-col min-h-dvh">
    <Navbar />
    <main class="grow">
      <slot />
    </main>
    <Footer />
    <script>
      function initReveal() {
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('active');
          });
        }, observerOptions);
        document
          .querySelectorAll('.reveal')
          .forEach((el) => observer.observe(el));
      }

      // Runs on initial load and after every View Transition navigation
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
